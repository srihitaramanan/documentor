# ---- LLM Provider (Day 1: Ollama, local, free) ----------------------------
# To switch providers later, change SPRING_AI_PROVIDER and set the matching key.
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ---- (later) OpenAI / Anthropic — kept here for reference -----------------
# OPENAI_API_KEY=sk-replace-me
# ANTHROPIC_API_KEY=sk-ant-replace-me

# ---- Database -------------------------------------------------------------
DB_URL=jdbc:postgresql://localhost:5432/documentor
DB_USER=documentor
DB_PASSWORD=documentor

# ---- JWT (used once we add auth in Day 2) ---------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-256-bit-random-hex-string
JWT_EXPIRY_HOURS=24

# ---- Storage --------------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./data/blobs

# ---- Limits ---------------------------------------------------------------
UPLOAD_MAX_SIZE_MB=50
RATE_LIMIT_QUERIES_PER_MINUTE=30