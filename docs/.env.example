# LLM Provider — set ONE provider and the matching API key
SPRING_AI_PROVIDER=openai            # openai | anthropic | ollama

OPENAI_API_KEY=sk-replace-me
# ANTHROPIC_API_KEY=sk-ant-replace-me

# Models
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Database (defaults match docker-compose.yml)
DB_URL=jdbc:postgresql://postgres:5432/documentor
DB_USER=documentor
DB_PASSWORD=changeme

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-256-bit-random-hex-string
JWT_EXPIRY_HOURS=24

# Storage
STORAGE_BACKEND=local                # local | s3
STORAGE_LOCAL_PATH=/var/documentor/blobs

# Limits
UPLOAD_MAX_SIZE_MB=50
RATE_LIMIT_QUERIES_PER_MINUTE=30
